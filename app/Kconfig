source "Kconfig.zephyr"

config APP_VERSION
	string "Application version"
	default "0.3.0"
	help
	  Firmware version string reported at boot and used for telemetry.

config BIKE_MQTT_RX_BUFFER_SIZE
	int "MQTT RX buffer size"
	default 512
	help
	  Receive buffer size used by the raw Zephyr MQTT client.

config BIKE_MQTT_TX_BUFFER_SIZE
	int "MQTT TX buffer size"
	default 512
	help
	  Transmit buffer size used by the raw Zephyr MQTT client.

config BIKE_MQTT_PAYLOAD_BUFFER_SIZE
	int "MQTT command payload log buffer size"
	default 256
	help
	  Maximum number of payload bytes copied before logging a command.

config BIKE_MQTT_THREAD_STACK_SIZE
	int "MQTT worker thread stack size"
	default 4096
	help
	  Stack size for the MQTT socket poll and keepalive worker.

config BIKE_MQTT_THREAD_PRIORITY
	int "MQTT worker thread priority"
	default 7
	help
	  Priority for the MQTT socket poll and keepalive worker.

config BIKE_TELEMETRY_PERIOD_SECONDS
	int "Telemetry publish period in seconds"
	default 10
	help
	  Period used by the telemetry work item to publish samples on zbus.

config BIKE_GNSS
	bool "Enable best-effort GNSS sampling"
	default n
	depends on NRF_MODEM_LIB
	help
	  Enable direct nRF modem GNSS sampling for nRF9160 targets. The module
	  starts from background work and keeps reporting no-fix telemetry if GNSS
	  cannot start or has not acquired a fix.

config BIKE_GNSS_FIX_INTERVAL_SECONDS
	int "GNSS fix interval in seconds"
	default 10
	depends on BIKE_GNSS
	help
	  Time between GNSS fixes. Use 1 for continuous navigation mode, or 10
	  or more for periodic navigation mode.

config BIKE_GNSS_FIX_RETRY_SECONDS
	int "GNSS fix retry timeout in seconds"
	default 30
	depends on BIKE_GNSS
	help
	  Maximum time GNSS should search for a fix during each periodic window.

config BIKE_GNSS_LOW_ACCURACY
	bool "Allow low-accuracy GNSS fixes"
	default n
	depends on BIKE_GNSS
	help
	  Allow the modem GNSS stack to report low-accuracy fixes when a normal
	  accuracy fix is not available.

config BIKE_GNSS_PRIORITY_MODE
	bool "Prioritize GNSS over LTE"
	default y
	depends on BIKE_GNSS
	help
	  Enable modem GNSS priority mode so GNSS can get priority over LTE when
	  searching for a fix.
